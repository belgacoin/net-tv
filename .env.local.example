# =============================================================================
# NetTV - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED VARIABLES
# -----------------------------------------------------------------------------

# Production site URL (used for SEO, sitemap, and canonical URLs)
# Example: https://nettv.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# ANALYTICS (Optional)
# -----------------------------------------------------------------------------

# Google Analytics 4 Measurement ID
# Get yours at: https://analytics.google.com/
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# -----------------------------------------------------------------------------
# AFFILIATE CONFIGURATION (Optional)
# -----------------------------------------------------------------------------

# Default affiliate ID used across all services
# This can be overridden by service-specific IDs below
NEXT_PUBLIC_AFFILIATE_ID=

# Service-specific affiliate IDs
# Uncomment and fill in the services you have affiliate partnerships with

# Netflix Affiliate URL
# NEXT_PUBLIC_NETFLIX_AFFILIATE=https://www.netflix.com/your-affiliate-code

# Disney+ Affiliate URL
# NEXT_PUBLIC_DISNEY_AFFILIATE=https://www.disneyplus.com/your-affiliate-code

# HBO Max Affiliate URL
# NEXT_PUBLIC_HBO_AFFILIATE=https://www.hbomax.com/your-affiliate-code

# Hulu Affiliate URL
# NEXT_PUBLIC_HULU_AFFILIATE=https://www.hulu.com/your-affiliate-code

# Amazon Prime Video Affiliate URL
# NEXT_PUBLIC_PRIME_AFFILIATE=https://www.amazon.com/your-affiliate-code

# Apple TV+ Affiliate URL
# NEXT_PUBLIC_APPLE_TV_AFFILIATE=https://tv.apple.com/your-affiliate-code

# Paramount+ Affiliate URL
# NEXT_PUBLIC_PARAMOUNT_AFFILIATE=https://www.paramountplus.com/your-affiliate-code

# Peacock Affiliate URL
# NEXT_PUBLIC_PEACOCK_AFFILIATE=https://www.peacocktv.com/your-affiliate-code

# Discovery+ Affiliate URL
# NEXT_PUBLIC_DISCOVERY_AFFILIATE=https://www.discoveryplus.com/your-affiliate-code

# YouTube TV Affiliate URL
# NEXT_PUBLIC_YOUTUBE_TV_AFFILIATE=https://tv.youtube.com/your-affiliate-code

# -----------------------------------------------------------------------------
# ADVANCED CONFIGURATION (Optional)
# -----------------------------------------------------------------------------

# Disable Next.js telemetry
# Set to 1 to disable anonymous usage data collection
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# DEVELOPMENT VARIABLES (Only for local development)
# -----------------------------------------------------------------------------

# Enable verbose logging
# DEBUG=true

# API endpoint for development (if using external APIs)
# NEXT_PUBLIC_API_URL=http://localhost:3001
