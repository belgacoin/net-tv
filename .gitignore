# =============================================================================
# NetTV - Git Ignore File
# =============================================================================
# This file specifies intentionally untracked files to ignore
# =============================================================================

# -----------------------------------------------------------------------------
# DEPENDENCIES
# -----------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
package-lock.json
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# TESTING
# -----------------------------------------------------------------------------
/coverage
.nyc_output

# -----------------------------------------------------------------------------
# NEXT.JS BUILD OUTPUT
# -----------------------------------------------------------------------------
/.next/
/out/

# -----------------------------------------------------------------------------
# PRODUCTION BUILD
# -----------------------------------------------------------------------------
/build
/dist

# -----------------------------------------------------------------------------
# ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------
# Never commit environment variables to version control
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# -----------------------------------------------------------------------------
# ENVIRONMENT TEMPLATE IS ALLOWED
# -----------------------------------------------------------------------------
# .env.local.example should be committed as a template

# -----------------------------------------------------------------------------
# VERCEL DEPLOYMENT
# -----------------------------------------------------------------------------
.vercel

# -----------------------------------------------------------------------------
# TYPESCRIPT
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# IDE AND EDITOR FILES
# -----------------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IntelliJ / WebStorm
.idea/
*.iml
*.iws
*.ipr
*.ids
*.orig

# Sublime Text
*.sublime-workspace
*.sublime-project

# Atom
.atom/

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# -----------------------------------------------------------------------------
# OPERATING SYSTEM FILES
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# -----------------------------------------------------------------------------
# MISCELLANEOUS
# -----------------------------------------------------------------------------
# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Temporary files
*.tmp
*.temp
*.log

# Local Netlify folder
.netlify

# Storybook build
storybook-static

# PWA files
**/public/sw.js
**/public/workbox-*.js
**/public/worker-*.js
**/public/sw.js.map
**/public/workbox-*.js.map
**/public/worker-*.js.map

# Sitemap (generated at build time)
public/sitemap.xml
public/sitemap-*.xml
public/robots.txt

# RSS feed (generated at build time)
public/feed.xml

# Search index (generated at build time)
public/search-index.json
